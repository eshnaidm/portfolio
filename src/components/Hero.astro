---
const codeHtml = `<span class="kw">const</span> <span class="var">developer</span> = {
  <span class="prop">name</span>: <span class="str">"Erich Shnaidman"</span>,
  <span class="prop">roles</span>: [
    <span class="str">"Game Designer"</span>,
    <span class="str">"QA Tester"</span>,
    <span class="str">"Full-Stack Developer"</span>
  ],
  <span class="prop">stack</span>: [
    <span class="str">"Kotlin"</span>, <span class="str">"Next.js"</span>,
    <span class="str">"TypeScript"</span>, <span class="str">"Docker"</span>
  ],
  <span class="prop">tools</span>: [
    <span class="str">"Claude Code"</span>,
    <span class="str">"Codex"</span>
  ],
  <span class="prop">available</span>: <span class="bool">true</span>
};`;
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content fade-in">
      <p class="hero-greeting">Hi, I'm</p>
      <h1>Erich Shnaidman</h1>
      <p class="hero-title">Game Designer & QA Tester & Developer</p>
      <p class="hero-subtitle">
        I design game systems, build full-stack applications, and write comprehensive
        test plans. From Android games to web CRMs — I bring ideas to life with
        modern tools and AI-assisted development.
      </p>
      <a href="#projects" class="hero-cta">View My Work</a>
    </div>
    <div class="hero-visual fade-in">
      <div class="terminal-card">
        <div class="terminal-header">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">portfolio.ts</span>
        </div>
        <div class="terminal-body">
          <pre><code set:html={codeHtml} /></pre>
        </div>
      </div>
    </div>
    <div class="hero-glow"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
  }

  .hero-greeting {
    color: var(--accent-primary);
    font-weight: 500;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .hero h1 {
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    color: var(--text-secondary);
    max-width: 550px;
    margin-bottom: 2rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .hero-cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--accent-primary);
    color: white;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.9rem;
    transition: background var(--transition), transform var(--transition);
  }

  .hero-cta:hover {
    background: var(--accent-hover);
    color: white;
    transform: translateY(-2px);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    animation-delay: 0.3s;
  }

  .terminal-card {
    width: 100%;
    max-width: 420px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 40px var(--accent-glow);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.75rem 1rem;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.yellow { background: #eab308; }
  .terminal-dot.green { background: #22c55e; }

  .terminal-title {
    margin-left: 8px;
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
  }

  .terminal-body {
    padding: 1.25rem 1.5rem;
  }

  .terminal-body pre {
    margin: 0;
    background: none;
    border: none;
    padding: 0;
  }

  .terminal-body code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    line-height: 1.7;
    background: none;
    padding: 0;
    color: var(--text-secondary);
  }

  .terminal-body :global(.kw) { color: #c678dd; }
  .terminal-body :global(.var) { color: #e5c07b; }
  .terminal-body :global(.prop) { color: #61afef; }
  .terminal-body :global(.str) { color: #98c379; }
  .terminal-body :global(.bool) { color: #d19a66; }

  .hero-glow {
    position: absolute;
    top: 20%;
    right: 5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
    }
    .hero-glow {
      width: 300px;
      height: 300px;
      top: 10%;
      right: -20%;
    }
  }
</style>
