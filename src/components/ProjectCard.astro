---
interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  slug: string;
  githubUrl?: string;
}

const { title, description, category, tags, slug, githubUrl } = Astro.props;
---

<div class="project-card" data-category={category}>
  <a href={`/projects/${slug}`} class="card-main">
    <div class="card-header">
      <span class={`badge badge-${category}`}>
        {category === 'qa' ? 'QA Testing' : category === 'game-design' ? 'Game Design' : 'AI-Built'}
      </span>
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <div class="card-tags">
      {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
    </div>
  </a>
  {githubUrl && (
    <a href={githubUrl} target="_blank" rel="noopener" class="github-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      View on GitHub
    </a>
  )}
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    overflow: hidden;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-primary);
    box-shadow: 0 8px 30px var(--accent-glow);
  }

  .card-main {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    flex: 1;
    color: var(--text-primary);
  }

  .card-main:hover {
    color: var(--text-primary);
  }

  .card-header {
    margin-bottom: 1rem;
  }

  .project-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
  }

  .project-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    padding: 0.2rem 0.5rem;
    background: var(--bg-tertiary);
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .github-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.75rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-secondary);
    transition: background var(--transition), color var(--transition);
  }

  .github-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }
</style>
