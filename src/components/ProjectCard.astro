---
interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  slug: string;
}

const { title, description, category, tags, slug } = Astro.props;
---

<a href={`/projects/${slug}`} class="project-card" data-category={category}>
  <div class="card-header">
    <span class={`badge badge-${category}`}>
      {category === 'qa' ? 'QA Testing' : category === 'game-design' ? 'Game Design' : 'Development'}
    </span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="card-tags">
    {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    color: var(--text-primary);
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-primary);
    box-shadow: 0 8px 30px var(--accent-glow);
    color: var(--text-primary);
  }

  .card-header {
    margin-bottom: 1rem;
  }

  .project-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
  }

  .project-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    padding: 0.2rem 0.5rem;
    background: var(--bg-tertiary);
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
</style>
