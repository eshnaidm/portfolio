---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: string;
}

const { title, description, category, tags, date } = Astro.props;
---

<BaseLayout title={`${title} — Erich Shnaidman`} description={description}>
  <Header />
  <main class="project-page">
    <div class="container">
      <a href="/#projects" class="back-link">&larr; Back to Projects</a>
      <article class="project-content">
        <header class="project-header">
          <div class="project-meta">
            <span class={`badge badge-${category}`}>
              {category === 'qa' ? 'QA Testing' : category === 'game-design' ? 'Game Design' : 'Development'}
            </span>
            <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</time>
          </div>
          <h1>{title}</h1>
          <p class="project-description">{description}</p>
          <div class="project-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding-top: 6rem;
    min-height: 100vh;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--accent-primary);
  }

  .project-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .project-meta time {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .project-header h1 {
    margin-bottom: 0.75rem;
  }

  .project-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 700px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .tag {
    padding: 0.2rem 0.6rem;
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .prose {
    max-width: 800px;
  }

  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    color: var(--text-secondary);
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    color: var(--text-primary);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent-primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    display: block;
    overflow-x: auto;
  }

  .prose :global(th) {
    background: var(--bg-tertiary);
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
  }

  .prose :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(tr:hover td) {
    background: var(--bg-secondary);
  }

  .prose :global(code) {
    background: var(--bg-tertiary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
  }

  .prose :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .project-page {
      padding-top: 5rem;
    }
  }
</style>
